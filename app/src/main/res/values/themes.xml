<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Emilla.DayNight" parent="Theme.MaterialComponents.NoActionBar" />

    <style name="Theme.Emilla.Base" parent="Theme.Emilla.DayNight">
        <item name="preferenceTheme">@style/SettingsTheme</item>

        <item name="alertDialogStyle">@style/AlertDialog.Emilla</item>
        <item name="android:buttonBarButtonStyle">@style/Widget.Emilla.Button.TextButton</item>
        <item name="textAppearanceButton">@style/TextAppearance.Emilla.Button</item>
        <item name="listDividerAlertDialog">@drawable/list_divider_emilla</item>
        <item name="selectableItemBackground">@drawable/bg_selectable_item</item>
    </style>

    <style name="Theme.Emilla" parent="Theme.Emilla.Base">
        <item name="colorPrimary">@color/main_200</item>
        <item name="colorPrimaryVariant">@color/main_700</item>
        <item name="colorOnPrimary">@android:color/black</item>
        <item name="colorSecondary">@color/secn_200</item>
        <item name="colorSecondaryVariant">@color/secn_700</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="colorSecondaryContainer">@color/secn_background_dark</item>
        <item name="colorBackgroundFloating">@color/secn_background_dark</item>
        <item name="colorSucceed">@color/main_400</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:windowBackground">@color/main_background_dark</item>
    </style>

    <style name="Theme.Assistant.Base" parent="Theme.Emilla">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Theme.Assistant" parent="Theme.Assistant.Base">
        <item name="colorBackgroundFloating">@color/main_background_dark</item>
    </style>

</resources>